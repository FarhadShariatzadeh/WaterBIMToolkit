<Window x:Class="WaterBIMToolkit.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Water BIM Toolkit" Height="620" Width="900"
        MinHeight="450" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">

    <Window.Resources>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="BorderBrush" Value="#3A3A5C"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="Background" Value="#2A2A40"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="Background" Value="#89B4FA"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#B4C8F8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#45475A"/>
                                <Setter Property="Foreground" Value="#6C7086"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="SecondaryButton" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#A6E3A1"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#181825"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#3A3A5C"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#313244"/>
            <Setter Property="RowBackground" Value="#181825"/>
            <Setter Property="AlternatingRowBackground" Value="#1E1E2E"/>
            <Setter Property="ColumnHeaderHeight" Value="32"/>
            <Setter Property="RowHeight" Value="28"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#89B4FA"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="BorderBrush" Value="#3A3A5C"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#313244" Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="💧" FontSize="22" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <StackPanel>
                    <TextBlock Text="Water BIM Toolkit" Foreground="#CDD6F4"
                               FontSize="16" FontWeight="Bold"/>
                    <TextBlock Text="MEP Validator  ·  Equipment Schedule Generator"
                               Foreground="#6C7086" FontSize="11"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Tab Content -->
        <TabControl Grid.Row="1" x:Name="MainTabs" Margin="0">

            <!-- ===== TAB 1: MEP VALIDATOR ===== -->
            <TabItem Header="⚙  MEP Validator">
                <Grid Background="#1E1E2E" Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Validator controls -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button x:Name="BtnRunValidation" Content="▶  Run Validation"
                                Style="{StaticResource ActionButton}"
                                Click="BtnRunValidation_Click"/>
                        <Button x:Name="BtnExportValidation" Content="⬇  Export CSV"
                                Style="{StaticResource SecondaryButton}"
                                Margin="8,0,0,0" IsEnabled="False"
                                Click="BtnExportValidation_Click"/>
                        <ComboBox x:Name="SeverityFilter" Width="120" Margin="16,0,0,0"
                                  VerticalAlignment="Center"
                                  Background="#313244" Foreground="#CDD6F4"
                                  SelectionChanged="SeverityFilter_Changed">
                            <ComboBoxItem Content="All" IsSelected="True"/>
                            <ComboBoxItem Content="Error"/>
                            <ComboBoxItem Content="Warning"/>
                            <ComboBoxItem Content="Info"/>
                        </ComboBox>
                        <TextBlock x:Name="ValidationSummary"
                                   Foreground="#6C7086" FontSize="12"
                                   VerticalAlignment="Center" Margin="16,0,0,0"/>
                    </StackPanel>

                    <!-- Check legend -->
                    <WrapPanel Grid.Row="1" Margin="0,0,0,8">
                        <Border Background="#313244" CornerRadius="3" Padding="8,3" Margin="0,0,6,4">
                            <TextBlock FontSize="11" Foreground="#CDD6F4">
                                <Run Foreground="#F38BA8">●</Run>
                                <Run> Pipe Slope</Run>
                            </TextBlock>
                        </Border>
                        <Border Background="#313244" CornerRadius="3" Padding="8,3" Margin="0,0,6,4">
                            <TextBlock FontSize="11" Foreground="#CDD6F4">
                                <Run Foreground="#FAB387">●</Run>
                                <Run> Pump Connectivity</Run>
                            </TextBlock>
                        </Border>
                        <Border Background="#313244" CornerRadius="3" Padding="8,3" Margin="0,0,6,4">
                            <TextBlock FontSize="11" Foreground="#CDD6F4">
                                <Run Foreground="#F9E2AF">●</Run>
                                <Run> Isolation Valves</Run>
                            </TextBlock>
                        </Border>
                        <Border Background="#313244" CornerRadius="3" Padding="8,3" Margin="0,0,6,4">
                            <TextBlock FontSize="11" Foreground="#CDD6F4">
                                <Run Foreground="#A6E3A1">●</Run>
                                <Run> Pipe Size</Run>
                            </TextBlock>
                        </Border>
                    </WrapPanel>

                    <!-- Results grid -->
                    <DataGrid Grid.Row="2" x:Name="ValidationGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="Error">
                                                <Setter Property="Foreground" Value="#F38BA8"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </Trigger>
                                            <Trigger Property="Text" Value="Warning">
                                                <Setter Property="Foreground" Value="#F9E2AF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="150"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                            <DataGridTextColumn Header="Element ID" Binding="{Binding ElementId}" Width="90"/>
                            <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ===== TAB 2: EQUIPMENT SCHEDULE ===== -->
            <TabItem Header="📋  Equipment Schedule">
                <Grid Background="#1E1E2E" Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Schedule controls -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button x:Name="BtnGenerateSchedule" Content="▶  Generate Schedule"
                                Style="{StaticResource ActionButton}"
                                Click="BtnGenerateSchedule_Click"/>
                        <Button x:Name="BtnExportSchedule" Content="⬇  Export CSV"
                                Style="{StaticResource SecondaryButton}"
                                Margin="8,0,0,0" IsEnabled="False"
                                Click="BtnExportSchedule_Click"/>
                        <TextBlock x:Name="ScheduleSummary"
                                   Foreground="#6C7086" FontSize="12"
                                   VerticalAlignment="Center" Margin="16,0,0,0"/>
                    </StackPanel>

                    <!-- Schedule grid -->
                    <DataGrid Grid.Row="1" x:Name="ScheduleGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Element ID" Binding="{Binding ElementId}" Width="85"/>
                            <DataGridTextColumn Header="Family" Binding="{Binding FamilyName}" Width="180"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding TypeName}" Width="140"/>
                            <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="100"/>
                            <DataGridTextColumn Header="Flow Rate" Binding="{Binding FlowRate}" Width="95"/>
                            <DataGridTextColumn Header="TDH" Binding="{Binding TotalDynamicHead}" Width="85"/>
                            <DataGridTextColumn Header="Motor HP" Binding="{Binding MotorHP}" Width="85"/>
                            <DataGridTextColumn Header="Material" Binding="{Binding Material}" Width="100"/>
                            <DataGridTextColumn Header="Clearance" Binding="{Binding ClearanceStatus}" Width="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="OK">
                                                <Setter Property="Foreground" Value="#A6E3A1"/>
                                            </Trigger>
                                        </Style.Triggers>
                                        <Setter Property="Foreground" Value="#F9E2AF"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="#313244" Padding="12,5">
            <TextBlock x:Name="StatusBar" Foreground="#6C7086" FontSize="11"
                       Text="Ready — open a Revit project and click Run to begin."/>
        </Border>
    </Grid>
</Window>
